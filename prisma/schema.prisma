generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id        String   @id @default(uuid())
  title     String
  content   String
  category  String
  createdAt DateTime @default(now())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
}

model PasswordResetOTP {
  id        String   @id @default(uuid())
  email     String
  otp       String
  expiresAt DateTime
}

model RegistrationOTP {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  otpHash      String
  attempts     Int      @default(0)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
  @@index([expiresAt])
}

model Part {
  id           String    @id @default(uuid())
  partNumber   String
  title        String
  range        String
  articles     Int
  description  String?
  createdAt    DateTime  @default(now())
  articlesList Article[]
}

model Article {
  id                String   @id @default(uuid())
  articleNumber     String
  title             String
  shortSummary      String?
  officialText      String?
  simpleExplanation String?
  example           String?
  tags              String?
  featured          Boolean  @default(false)
  partId            String
  createdAt         DateTime @default(now())
  part              Part     @relation(fields: [partId], references: [id])
  clauses           Clause[]
}

model Clause {
  id           String   @id @default(uuid())
  clauseNumber String
  text         String
  createdAt    DateTime @default(now())
  articleId    String
  article      Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Preamble {
  id                String   @id @default("singleton")
  officialText      String
  simpleExplanation String
  whyItMatters      String
  keywords          String   @default("[]")
  timeline          String   @default("[]")
  quickFacts        String   @default("[]")
  updatedAt         DateTime @updatedAt
  landmarkCases     String   @default("[]")
  notes             String   @default("[]")
}

model Schedule {
  id          String   @id @default(uuid())
  shortId     String
  schedule    String
  title       String
  description String?
  topics      String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  slug        String   @unique
  tagDetails  String   @default("[]")
}

model Amendment {
  id              String   @id @default(uuid())
  number          String
  year            String
  title           String
  summary         String
  whyItMatters    String?
  relatedArticles String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Quiz {
  id          String            @id @default(uuid())
  title       String
  level       String
  status      String            @default("draft")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  description String?
  timeMinutes Int               @default(10)
  questions   Question[]
  attempts    UserQuizAttempt[]
}

model Question {
  id            String   @id @default(uuid())
  questionText  String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String
  explanation   String?
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model UserQuizAttempt {
  id          String   @id @default(uuid())
  userId      String
  quizId      String
  score       Int
  totalQ      Int
  answers     String
  submittedAt DateTime @default(now())
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quizId])
  @@index([userId])
  @@index([quizId])
}

model Feedback {
  id        String   @id @default(uuid())
  userId    String
  rating    Int
  name      String?
  comment   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model User {
  id                  String               @id @default(uuid())
  name                String?
  email               String               @unique
  password            String
  role                Role                 @default(USER)
  status              Status               @default(ACTIVE)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  avatar              String?
  lastLogin           DateTime?
  isDeleted           Boolean              @default(false)
  feedbacks           Feedback[]
  passwordResetTokens PasswordResetToken[]
  posts               Post[]
  quizAttempts        UserQuizAttempt[]

  @@index([email])
  @@index([role])
  @@index([status])
}

enum Role {
  USER
  ADMIN
}

enum Status {
  ACTIVE
  BLOCKED
  SUSPENDED
}
